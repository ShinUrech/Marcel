# =============================================
# Docker Compose Environment Variables
# Copy this file to .env and fill in values:
#   cp .env.example .env
#
# LOCAL DEV:  use docker-compose.yml (includes local MongoDB)
# PRODUCTION: use docker-compose.prod.yml (requires MongoDB Atlas URI)
# =============================================

# --- MongoDB ---
# Local dev only (docker-compose.yml)
MONGO_INITDB_DATABASE=practicedb
# For production, set this to your MongoDB Atlas connection string:
MONGO_URI=mongodb://mongo:27017/practicedb
# Example Atlas URI:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/practicedb?retryWrites=true&w=majority

# --- Backend ---
PORT=5000
CHATGPT_API_KEY=sk-your-openai-api-key-here

# --- LinkedIn Scraper ---
# Run locally only — never triggered by the production server auto-cron.
# Trigger manually: GET http://localhost:5000/api/scraper/linkedin/sbb-cff-ffs
LINKEDIN_EMAIL=your-linkedin-email@example.com
LINKEDIN_PASSWORD=your-linkedin-password
LINKEDIN_LI_AT=

# --- Frontend (local dev / Docker) ---
NEXT_PUBLIC_API_URL=http://backend:5000
NEXT_PUBLIC_CLIENT_API_URL=http://localhost:5000

# --- Frontend (Vercel production) ---
# Set these in the Vercel dashboard under Project → Settings → Environment Variables:
# NEXT_PUBLIC_SERVER_URL=http://<your-droplet-ip>:5000/api
# NEXT_PUBLIC_SERVER_FILE_HOST=http://<your-droplet-ip>:5000/api/articles/show/
# APP_NAME=IRISO Bau AG
# APP_EMAIL=info@irisobau.ch
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASS=your-gmail-app-password

# --- Contact Form ---
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASS=your-gmail-app-password
CONTACT_RECEIVER=receiver@example.com

